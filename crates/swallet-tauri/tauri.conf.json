{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-settings/main/schemas/tauri-conf-v2.json",
  "productName": "swallet",
  "version": "0.1.0",
  "identifier": "com.swallet.app",
  "build": {
    "frontendDist": "../../ui/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../ui && npm run dev",
    "beforeBuildCommand": "cd ../../ui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "swallet",
        "width": 420,
        "height": 700,
        "resizable": true,
        "minWidth": 375,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
