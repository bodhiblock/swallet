{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-settings/main/schemas/tauri-conf-v2.json",
  "productName": "科学计算器",
  "version": "0.1.0",
  "identifier": "com.swallet.app",
  "build": {
    "frontendDist": "../../ui/build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": { "script": "npm run dev", "cwd": "../../ui" },
    "beforeBuildCommand": { "script": "npm run build", "cwd": "../../ui" }
  },
  "app": {
    "windows": [
      {
        "title": "科学计算器",
        "width": 420,
        "height": 700,
        "resizable": true,
        "minWidth": 375,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
